# Copy to deploy/.env and fill in. Compose reads this file for both
# interpolation (${...}) and gateway environment variables.

# --- required ---------------------------------------------------------------
# Comma-separated API keys clients must send in X-API-Key.
OMNIAI_API_KEYS=change-me-key-1

# Postgres password (used by both the postgres and gateway services).
POSTGRES_PASSWORD=change-me

# --- model ------------------------------------------------------------------
# HF model the vLLM container serves.
OMNIAI_MODEL=Qwen/Qwen2.5-7B-Instruct
# Token for gated models (optional).
HUGGING_FACE_HUB_TOKEN=

# --- security (optional overrides) -----------------------------------------
# OMNIAI_AUTH_DISABLED=false          # never enable in production
# OMNIAI_RATE_LIMIT_RPS=10
# OMNIAI_RATE_LIMIT_BURST=20
# OMNIAI_CORS_ORIGINS=https://app.example.com
# OMNIAI_MAX_BODY_BYTES=1000000

# --- reliability (optional overrides) --------------------------------------
# OMNIAI_REQUEST_TIMEOUT_S=120
# OMNIAI_ENGINE_RETRIES=3
# OMNIAI_BREAKER_FAILURE_THRESHOLD=5
# OMNIAI_BREAKER_RESET_S=30

# --- observability (optional) ----------------------------------------------
# OMNIAI_LOG_LEVEL=INFO
# OMNIAI_LOG_JSON=true
# OMNIAI_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
# OMNIAI_SERVICE_NAME=omniai-gateway

# Set automatically by docker-compose.yml (do not set here):
#   OMNIAI_DATABASE_URL, OMNIAI_ENGINE_BASE_URL, OMNIAI_ENGINE_MANAGED
